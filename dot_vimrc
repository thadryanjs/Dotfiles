nnoremap <Leader>sc :call slime#send_cell()<CR>
" Auto-detect target if possible, default zellij
let g:slime_target = getenv('TERMINAL_EMULATOR') == 'tmux' ? 'tmux' : 'zellij'

" Move lines (Shift+hjkl)
