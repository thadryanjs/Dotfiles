# short-lived session token, tmpfs, per-user, wiped on reboot
BW_SESSION_CACHE="${XDG_RUNTIME_DIR:-/tmp}/bw-session"

bw_unlock() {
  # reuse cached token if it's < 24h old and still valid
  if [ -f "$BW_SESSION_CACHE" ] && [ -z "$(find "$BW_SESSION_CACHE" -mmin +1440 2>/dev/null)" ]; then
    export BW_SESSION="$(cat "$BW_SESSION_CACHE")"
    bw status 2>/dev/null | grep -q '"status":"unlocked"' && return 0
  fi
  BW_SESSION="$(bw unlock --raw)" || return 1
  export BW_SESSION
  ( umask 077; printf '%s' "$BW_SESSION" >"$BW_SESSION_CACHE" )   # mode 600
}

with_llm_keys() {
  bw_unlock || return 1
  local items; items="$(bw list items 2>/dev/null)"   # ONE bw call instead of three
  OPENROUTER_API_KEY="$(jq -r '.[]|select(.name=="OpenRouterAPI").login.password'      <<<"$items")" \
  DEEPSEEK_API_KEY="$(jq -r '.[]|select(.name=="DeepSeekAPI").login.password'          <<<"$items")" \
  DARTMOUTH_CHAT_API_KEY="$(jq -r '.[]|select(.name=="DartmouthChatAPI").login.password' <<<"$items")" \
  BW_SESSION= \
  "$@"
}

opencode() { with_llm_keys command opencode "$@"; }
pi()       { with_llm_keys command pi "$@"; }


